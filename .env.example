# =============================================================================
# Red Arch Knowledge Management Platform - Environment Configuration
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=redarch
POSTGRES_PASSWORD=          # REQUIRED: set a strong password
POSTGRES_DB=redarch_km
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=             # Optional: set if using Qdrant Cloud

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=             # REQUIRED: set a strong password

# --- OpenAI ---
OPENAI_API_KEY=             # REQUIRED: your OpenAI API key (central fallback; per-org keys override)
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_OCR_MODEL=gpt-4.1-mini   # Vision model for the "ai" upload extraction method

# --- Object storage (MinIO / S3-compatible) — uploaded document originals ---
# Shared by the API (stores originals on upload) and the worker (downloads for
# OCR/extraction). STORAGE_ENDPOINT is the S3 API URL (in-cluster: minio:9000).
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin       # MinIO root user (dev default)
STORAGE_SECRET_KEY=                 # REQUIRED: MinIO root password (set a strong value)
STORAGE_BUCKET=km-documents         # Create this bucket once (see docker-compose.infra.yml)
STORAGE_REGION=us-east-1
MAX_FILE_SIZE_MB=50                 # Upload size cap (API rejects at the boundary)

# --- Clerk (identity provider) — backend verifier ---
# Backends (Go api-go + Python api) verify the session token by its issuer: the
# token's `iss` must match CLERK_JWT_ISSUER. Clerk default session tokens carry
# NO `aud`; the verifier instead enforces `azp` against CLERK_ALLOWED_AZP
# (mandatory when Clerk is enabled).
CLERK_JWT_ISSUER=            # Clerk Frontend API URL, e.g. https://clerk.example.com or https://<slug>.clerk.accounts.dev
# CLERK_ALLOWED_AZP must match Clerk's emitted `azp` (the UI Origin) BYTE-FOR-BYTE:
# scheme+host, no trailing slash, include the port only if the origin has one.
# A mismatch fails closed (rejects all Clerk tokens), so set it carefully.
CLERK_ALLOWED_AZP=http://localhost:3000   # REQUIRED w/ Clerk: comma-separated allowlist of UI origins (authorized parties)
CLERK_SECRET_KEY=           # Clerk Backend API secret (sk_…); also used by @clerk/nextjs server (middleware/SSR)

# --- Clerk — UI (@clerk/nextjs) ---
# The publishable key is exposed to the browser; the secret key (above) is read
# server-side by @clerk/nextjs. Sign-in/up live at /login and /sign-up.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=    # Clerk publishable key (pk_…)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Name of the Clerk JWT template (Phase 0, dashboard) that injects claims into
# the session token the UI sends as Bearer. SECURITY-CRITICAL: the template MUST
# emit email, email_verified, AND username — the api-go verifier provisions on
# email/username and gates the verified-email user RELINK on email_verified
# (omitting email = silent membership loss; omitting email_verified = first-login
# 403 lockout for migrated users). Verify the live token end-to-end against a
# real migrated profile before cutover. NOTE: Clerk renders an unknown shortcode
# as a LITERAL string, so the email_verified shortcode MUST be exactly
# {{user.email_verified}} (verified live to emit a boolean) — `user.
# primary_email_address_verified` is NOT a valid shortcode and renders literally,
# which makes email_verified never == true and 403-locks out every migrated user.
#   email          = {{user.primary_email_address}}
#   email_verified = {{user.email_verified}}
#   username       = {{user.username}}
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=redarch-km

# --- API Service ---
API_SECRET_KEY=             # REQUIRED: random string for JWT signing
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:3000"]
API_RATE_LIMIT_PER_MINUTE=60

# --- Brain API ---
BRAIN_API_KEY=              # REQUIRED: shared secret for service-to-service auth
BRAIN_CHUNK_COLLECTION_SUFFIX=chunks
BRAIN_DOCUMENT_COLLECTION_SUFFIX=documents
BRAIN_MAX_TOKENS=16000

# --- Internal API (worker → api callbacks) ---
# Separate from BRAIN_API_KEY so compromise of one doesn't grant the other.
# The api service rejects internal callbacks if this is empty.
INTERNAL_API_KEY=           # REQUIRED: shared secret for worker→api callbacks
API_URL=http://api:8000     # Where the worker POSTs processing-status callbacks

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=red-arch-km
LOG_LEVEL=INFO

# --- pgAdmin (dev only) ---
PGADMIN_DEFAULT_EMAIL=admin@redarchlabs.com
PGADMIN_DEFAULT_PASSWORD=   # Set for local dev only

# --- Flower (dev only) ---
FLOWER_BASIC_AUTH=admin:    # Set for local dev only
