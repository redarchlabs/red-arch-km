# =============================================================================
# Red Arch Knowledge Management Platform - Environment Configuration
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=redarch
POSTGRES_PASSWORD=          # REQUIRED: set a strong password
POSTGRES_DB=redarch_km
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=             # Optional: set if using Qdrant Cloud

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=             # REQUIRED: set a strong password

# --- OpenAI ---
OPENAI_API_KEY=             # REQUIRED: your OpenAI API key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Keycloak ---
KEYCLOAK_URL=http://auth.redarchlabs.local:8080
KEYCLOAK_REALM=redarch
KEYCLOAK_CLIENT_ID=redarch-km

# --- API Service ---
API_SECRET_KEY=             # REQUIRED: random string for JWT signing
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:3000"]
API_RATE_LIMIT_PER_MINUTE=60

# --- Brain API ---
BRAIN_API_KEY=              # REQUIRED: shared secret for service-to-service auth
BRAIN_CHUNK_COLLECTION_SUFFIX=chunks
BRAIN_DOCUMENT_COLLECTION_SUFFIX=documents
BRAIN_MAX_TOKENS=16000

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=red-arch-km
LOG_LEVEL=INFO

# --- pgAdmin (dev only) ---
PGADMIN_DEFAULT_EMAIL=admin@redarchlabs.com
PGADMIN_DEFAULT_PASSWORD=   # Set for local dev only

# --- Flower (dev only) ---
FLOWER_BASIC_AUTH=admin:    # Set for local dev only
