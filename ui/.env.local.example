# ui/.env.local.example — copy to ui/.env.local and fill in.
# ui/.env.local is GITIGNORED (root .gitignore: `.env.local`). NEVER commit real keys.
#
# These are the UI-side env vars needed for local E2E (E2E_WITH_BACKEND=1).
# Real values come from the Clerk TEST instance "magnetic-albacore-4"
# (Clerk dashboard -> API keys; development instance, pk_test_/sk_test_).
# Ask the team / see the work-order decision log for the current key values —
# do NOT hardcode them in tracked files.
#
# NOTE: the auth/RBAC E2E specs do NOT log in through Clerk — they bypass it via
# the API's X-Test-User header path (see docs/testing/e2e-seeded-auth.md). These
# Clerk keys only let the UI boot and satisfy smoke.spec.ts's redirect-to-/login
# assertion. No Clerk users need to be seeded.

# --- Clerk (UI @clerk/nextjs) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- API base URL (browser -> Python API, cross-origin :3000 -> :8000) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
