{
  "name": "km2-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Red Arch Knowledge Manager (KM2). Rides the user's live Clerk browser session to call the KM2 API on their behalf.",
  "type": "module",
  "bin": {
    "km2-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "postinstall-browser": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
